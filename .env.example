# Skillberry Proxy Agent Configuration
# =====================================

# ============================================================================
# QUICK START
# ============================================================================
# 1. Copy this file to .env
# 2. Choose a provider from the examples below
# 3. Uncomment and configure your chosen provider
# 4. Set the corresponding API credentials
#
# For detailed provider setup, see: docs/ports-and-env-vars.md
# ============================================================================

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Provider name - see examples below for all supported providers
SPA_PROVIDER_NAME=litellm.rits

# Model name to use with the provider
SPA_MODEL_NAME=openai/gpt-oss-120b

# LLM temperature (0.0 to 1.0)
SPA_TEMPERATURE=0

# ============================================================================
# PROVIDER EXAMPLES - Choose and configure your provider
# ============================================================================
# Uncomment and configure ONE of the following provider examples.
# Each provider requires specific environment variables (see below).

# ─────────────────────────────────────────────────────────────────────────
# Example 1: OpenAI (Recommended for community users)
# ─────────────────────────────────────────────────────────────────────────
# SPA_PROVIDER_NAME=openai.sync
# SPA_MODEL_NAME=gpt-4
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────
# Example 2: Anthropic Claude
# ─────────────────────────────────────────────────────────────────────────
# SPA_PROVIDER_NAME=anthropic.sync
# SPA_MODEL_NAME=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ─────────────────────────────────────────────────────────────────────────
# Example 3: Azure OpenAI
# ─────────────────────────────────────────────────────────────────────────
# SPA_PROVIDER_NAME=azure_openai.sync
# SPA_MODEL_NAME=gpt-4
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ─────────────────────────────────────────────────────────────────────────
# Example 4: Ollama (Local, no API key needed)
# ─────────────────────────────────────────────────────────────────────────
# SPA_PROVIDER_NAME=litellm.ollama
# SPA_MODEL_NAME=llama2
# OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────────────
# Example 5: RITS (External service - update URL per your RITS provider)
# ─────────────────────────────────────────────────────────────────────────
# SPA_PROVIDER_NAME=litellm.rits
# SPA_MODEL_NAME=openai/gpt-oss-120b
# RITS_API_KEY=your-rits-api-key
# RITS_API_URL=https://your-rits-endpoint.example.com

# ─────────────────────────────────────────────────────────────────────────
# Example 6: IBM LiteLLM (Update URL per your IBM LiteLLM endpoint)
# ─────────────────────────────────────────────────────────────────────────
# SPA_PROVIDER_NAME=litellm.ibm
# SPA_MODEL_NAME=GCP/claude-3-7-sonnet
# IBM_THIRD_PARTY_API_KEY=your-ibm-api-key
# IBM_LITELLM_API_BASE=https://your-ibm-litellm-endpoint.example.com

# ─────────────────────────────────────────────────────────────────────────
# Example 7: IBM WatsonX
# ─────────────────────────────────────────────────────────────────────────
# SPA_PROVIDER_NAME=watsonx.output_val
# SPA_MODEL_NAME=ibm/granite-13b-chat-v2
# WX_API_KEY=...
# WX_PROJECT_ID=...
# WX_URL=https://us-south.ml.cloud.ibm.com
# WX_SPACE_ID=...

# ============================================================================
# LLM PROVIDER CREDENTIALS
# ============================================================================
# Configure credentials for your chosen provider below.
# Only the credentials for your active provider are required.

# OpenAI API key (for openai.sync provider)
OPENAI_API_KEY=

# Anthropic API key (for anthropic.sync provider)
ANTHROPIC_API_KEY=

# Azure OpenAI credentials (for azure_openai.sync provider)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Ollama base URL (for litellm.ollama provider)
OLLAMA_BASE_URL=http://localhost:11434

# RITS API credentials (for litellm.rits provider)
# Update RITS_API_URL with your RITS provider endpoint
RITS_API_KEY=
RITS_API_URL=

# IBM LiteLLM API credentials (for litellm.ibm provider)
# Update IBM_LITELLM_API_BASE with your IBM LiteLLM endpoint
IBM_THIRD_PARTY_API_KEY=
IBM_LITELLM_API_BASE=

# WatsonX API credentials (for watsonx.output_val provider)
WX_API_KEY=
WX_PROJECT_ID=
WX_URL=https://us-south.ml.cloud.ibm.com
WX_SPACE_ID=

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Tools service base URL (Skillberry Store)
SPA_TOOLS_SERVICE_BASE_URL=http://127.0.0.1:8000

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Maximum number of agent iterations
SPA_TOOLS_REACT_AGENT__RECURSION_LIMIT=20

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Enable debug mode (true/false)
SPA_ADVANCED__DEBUG=false

# Log file path
SPA_ADVANCED__LOG_FILE=/tmp/tools-agent.log

# Enable OpenTelemetry logging (true/false)
SPA_ADVANCED__OTEL_LOGGING=false

# ============================================================================
# SKILL CONFIGURATION
# ============================================================================

# Direct skill UUID (highest priority)
SKILL_UUID=

# Skill name for resolution (used if SKILL_UUID not set)
SKILL_NAME=

# ============================================================================
# AGENT BEHAVIOR
# ============================================================================

# Enable agent tools (true/false)
USE_AGENT_TOOLS=true

# Enable agent prompts (true/false)
USE_AGENT_PROMPTS=true

# MCP prompts position (prefix/postfix)
MCP_PROMPTS_POSITION=postfix

# Enable thinking logs (true/false)
ENABLE_THINK_LOGS=false

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Priority Order: .env > config file > code defaults
# 2. Boolean values: true/false, 1/0, yes/no, on/off, enabled/disabled
# 3. Empty values are ignored (use the value from config file or defaults)
# 4. New attributes in config_structure.py automatically support env vars with SPA_ prefix
# 5. Nested attributes use double underscore: SPA_ADVANCED__DEBUG
# 6. Provider-specific credentials are read directly by llm-switchboard
# 7. Each provider requires different environment variables - see examples above
#
# For more information, see docs/ports-and-env-vars.md